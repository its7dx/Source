local Junkie = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()
Junkie.service = "Aerila"
Junkie.identifier = "1036673"
Junkie.provider = "Provider"

local AuthorizeToken = crypt.hash(tick()..tostring(math.random()), "sha256") -- Runtime verification token.
local WSS_TO_LOADTHIS_TOKEN = "JUNKIE_WSS_ONLY_v1"
local LOADTHIS_URL = "https://gistpad.com/raw/iidone-592"

local function OnKeyVerified()
    local env = getgenv and getgenv()
    if type(env) == "table" then
        env.__JUNKIE_WSS_TOKEN = WSS_TO_LOADTHIS_TOKEN
        env.__JUNKIE_WSS_VERIFY_TOKEN = AuthorizeToken
    end

    local ok, source = pcall(function()
        return game:HttpGet(LOADTHIS_URL)
    end)
    if not ok or type(source) ~= "string" then
        if type(env) == "table" then
            env.__JUNKIE_WSS_TOKEN = nil
            env.__JUNKIE_WSS_VERIFY_TOKEN = nil
        end
        return
    end

    local chunk = loadstring(source)
    if type(chunk) == "function" then
        chunk()
    end

    if type(env) == "table" then
        env.__JUNKIE_WSS_TOKEN = nil
        env.__JUNKIE_WSS_VERIFY_TOKEN = nil
    end
end

local env = getgenv and getgenv()
local scriptKey = type(env) == "table" and env.SCRIPT_KEY or nil
if type(scriptKey) ~= "string" or scriptKey == "" then
    return
end

local okCheck, result = pcall(function()
    return Junkie.check_key(scriptKey)
end)

if okCheck and result and (result.valid or result.message == "KEY_VALID" or result.message == "KEYLESS") then
    OnKeyVerified()
end
    